:usrpass
set /a usrpassatt+=1
if %usrpassatt% geq 3 (
    cls
    color 4C
    echo ╔══════════════════════════════════════╗
    echo ║         MINUX - SECURITY             ║
    echo ╠══════════════════════════════════════╣
    echo ║  Too many attempts!                  ║
    echo ║  Please wait 30 seconds...           ║
    echo ╚══════════════════════════════════════╝
    
    rem Таймер 30 секунд
    timeout /t 30 /nobreak >nul
    
    rem Сбрасываем счётчик
    set usrpassatt=0
    goto login
)
echo [ %date% %time% ] password verification >> session.log
set /p pass="user login: "
if "%pass%"=="1234" goto lic
)   else   (
    echo [ %date% %time% ] password incorrect >> session.log
    powershell -c "[System.Media.SystemSounds]::Beep.Play()"
    echo Password incorrect!
    goto login
)

