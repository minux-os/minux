:create_report
cls
title [Create Report]
echo MINUX Report > report.log
echo Version: NEXT >> report.log
echo Created automatically by Minux >> report.log
echo [%date%, %time%] >> report.log
echo Version: NEXT
:: CPU
for /f "delims=" %%a in ('powershell -Command "Get-CimInstance Win32_Processor | Select-Object -ExpandProperty Name"') do set "CPU=%%a"
echo CPU: %CPU% >> report.log

:: RAM
for /f "delims=" %%a in ('powershell -Command "[math]::Round((Get-CimInstance Win32_ComputerSystem).TotalPhysicalMemory/1GB, 2)"') do set "RAMGB=%%a"
echo RAM: %RAMGB% GB >> report.log

:: Определяем shell
if defined CMDCMDLINE (
    echo Shell: cmd.exe >> report.log
) else (
    echo Shell: PowerShell >> report.log
)
:: Новая супер-проверка
ping -n 3 8.8.8.8 | find "TTL=" >nul
if %errorlevel%==0 (set "INT=Connected") else (set "INT=Disconnected")

echo Internet: %INT% >> report.log
echo Session.log: >> report.log
type session.log >> report.log
echo Network Stats: >> report.log
echo 8.8.8.8: >> report.log
ping -n 3 8.8.8.8 >> report.log 2>&1
echo 9.9.9.9: >> report.log
ping -n 3 9.9.9.9 >> report.log 2>&1
echo ====================== >> report.log
echo Powered by Minux Team >> report.log
echo ====================== >> report.log
echo Success!
goto minux
)   else   (
    echo This is not command!
    goto minux
)
