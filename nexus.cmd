:lic
if exist ".license" goto check_license
echo 1. DO NOT EDIT THIS OS [/\] 
echo 2. EDIT YOUR DISTRO TO BASE MINUX [\/]
echo /\ - no
echo \/ - yes
echo Accept? (Y/N)
set /p accept=": "
if /i "%accept%"=="Y" (
    echo Y > .license
    goto minux
)
if /i "%accept%"=="N" (
    echo N > .license
    echo You locked!
    goto licno
)
echo Invalid choice! Please enter Y or N.
goto lic

:check_license
findstr /i "Y" .license >nul
if %errorlevel%==0 goto minux
findstr /i "N" .license >nul
if %errorlevel%==0 goto licno
REM Если в файле не Y и не N — КИДАЕМ В КОРЗИНУ!
echo [WARNING] License file corrupted! Moving to basket...
if not exist basket mkdir basket
move .license basket\
echo .license moved to basket at %date% %time% >> basket\log.txt
goto lic




